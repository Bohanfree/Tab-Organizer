{
  "manifest_version": 3,
  "name": "Atlas Tab Organizer",
  "description": "Auto-organize Chrome tabs into useful groups with optional AI instructions.",
  "version": "0.5.0",
  "permissions": ["tabs", "tabGroups", "storage", "windows"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Organize tabs",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  }
}
